		<div class='snor-band'>
            <div class="row w-75 mx-auto mt-1" id="head-options">
                <a href="../../Vehicles" class="col-4 snor-btn" open="{{{views.vehicles}}}">
                    Vehículos
                </a>
                <a href="../../Accessories" class="col-4 snor-btn" open="{{{views.accessories}}}">
                    Accesorios
                </a>
