                    <span class="hamburger-box">
                        <span class="hamburger-inner"></span>
                    </span>
                </button>
            </div>
            {{#if modal}}
                <div class="snor-filter" data-toggle="modal" data-target="#ModalFiltro" onclick="showFilter()">
                    <i class="fas fa-filter"></i>
                </div>
            {{/if}}
            <nav class="accordion-item bg-black">
				<div id="Options" class="collapse text-center row">
                    <a href="../../Vehicles" class="col-3 snor-btn w-100" open="{{{views.vehicles}}}">
                        Vehiculos
                    </a>
                    <a href="../../Accessories" class="col-3 snor-btn w-100" open="{{{views.accessories}}}">
                        Accesorios
                    </a>
                    <a href="../../Distribution" class="col-3 snor-btn w-100" open="{{{views.distribution}}}">
                        Distribucion
                    </a>
				</div>
			</nav>
        </div>
        <div class="snor-band bg-green"></div>
	</header>
